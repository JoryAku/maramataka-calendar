# API runtime
NODE_ENV=production
PORT=3000

# Comma-separated frontend origins allowed to call the API in production.
# Example: CORS_ORIGINS=https://maramataka.example.nz,https://www.maramataka.example.nz
CORS_ORIGINS=https://maramataka.example.nz

# JSON/form request body limit.
REQUEST_BODY_LIMIT=100kb

# Set when the API runs behind a trusted platform proxy/load balancer.
# Common values are 1, loopback, linklocal, uniquelocal, or a proxy IP/CIDR.
TRUST_PROXY=1

# Use stub only for deterministic local, test, or CI environments.
# Leave unset in production to use the live astronomy provider.
# MARAMATAKA_ASTRONOMY_MODE=stub

# Persistent astronomy cache location.
MARAMATAKA_ASTRONOMY_CACHE_PATH=.cache/astronomy.json
