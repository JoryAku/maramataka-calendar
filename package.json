{
  "name": "@maramataka-calendar/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "check:runtime": "node tools/check-node-version.js",
    "prestart": "npm run check:runtime",
    "preserve:api": "npm run check:runtime",
    "prelint": "npm run check:runtime",
    "pretest": "npm run check:runtime",
    "prebuild": "npm run check:runtime",
    "pree2e": "npm run check:runtime",
    "precheck": "npm run check:runtime",
    "preverify": "npm run check:runtime",
    "preverify:fast": "npm run check:runtime",
    "predev:all": "npm run check:runtime",
    "preci": "npm run check:runtime",
    "start": "env -u NO_COLOR nx serve maramataka-calendar",
    "serve:api": "env -u NO_COLOR nx serve api",
    "dev:all": "env -u NO_COLOR npm exec -- nx run-many -t serve -p api,maramataka-calendar --parallel=2",
    "lint": "env -u NO_COLOR nx run-many -t lint",
    "test": "env -u NO_COLOR nx run-many -t test",
    "build": "env -u NO_COLOR nx run-many -t build",
    "e2e": "env -u NO_COLOR nx run-many -t e2e",
    "compare:matariki-holiday": "TS_NODE_PROJECT=tsconfig.base.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' ts-node -r tsconfig-paths/register tools/compare-matariki-holiday.ts",
    "diagnose:maramataka": "TS_NODE_PROJECT=tsconfig.base.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' ts-node -r tsconfig-paths/register tools/maramataka-diagnostics.ts",
    "check": "env -u NO_COLOR nx run-many -t lint test build",
    "verify:fast": "env -u NO_COLOR npm exec -- nx run-many -t test build -p api,maramataka-domain,astronomy,location --skipNxCache --outputStyle=static && git diff --check",
    "verify": "env -u NO_COLOR npm exec -- nx run-many -t lint test build --skipNxCache --outputStyle=static && git diff --check",
    "ci": "MARAMATAKA_ASTRONOMY_MODE=stub env -u NO_COLOR nx run-many -t lint test build e2e"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0",
    "npm": ">=10"
  },
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "astronomy-engine": "^2.1.19",
    "axios": "^1.6.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "23.0.1",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/nest": "^23.0.1",
    "@nx/node": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/webpack": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.37.0",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.0.8",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.1"
  },
  "overrides": {
    "multer": "2.2.0"
  }
}
